    <div style={{background:'#050f05', border:'1px solid #1a3a1a',
                 borderRadius:'12px', padding:'14px', marginTop:'10px'}}>
      <div style={{display:'flex', alignItems:'center', gap:'8px', marginBottom:'12px'}}>
