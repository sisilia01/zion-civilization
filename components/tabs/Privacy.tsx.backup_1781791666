        <span style={{marginLeft:'auto', background:'#0a1a0a', border:'1px solid #1a3a1a',
                      borderRadius:'4px', padding:'2px 8px', color:'#00ff41',
                      fontSize:'0.6rem', fontFamily:'monospace'}}>
          WALRUS
