[Unit]
Description=ZION API
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/zion_backend
EnvironmentFile=/root/zion_backend/.env
ExecStart=/usr/bin/python3 -m uvicorn api:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
